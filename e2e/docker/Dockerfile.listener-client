FROM node:20-slim AS builder
WORKDIR /src
COPY clients/shared clients/shared
COPY clients/listener clients/listener
RUN cd clients/listener && npm install && npm run build

FROM nginx:alpine
COPY --from=builder /src/clients/listener/dist /usr/share/nginx/html
COPY e2e/docker/nginx-spa.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
