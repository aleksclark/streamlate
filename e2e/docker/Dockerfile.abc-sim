FROM rust:1-bookworm AS builder
WORKDIR /src
RUN apt-get update && apt-get install -y pkg-config libopus-dev && rm -rf /var/lib/apt/lists/*
COPY . .
RUN cargo build --release -p streamlate-abc --features headless

FROM debian:bookworm-slim
RUN apt-get update && apt-get install -y ca-certificates libopus0 && rm -rf /var/lib/apt/lists/*
COPY --from=builder /src/target/release/streamlate-abc /usr/local/bin/
EXPOSE 9090
CMD ["streamlate-abc", "--headless"]
